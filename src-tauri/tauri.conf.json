{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StoryForge",
  "version": "0.1.0",
  "identifier": "com.storyforge.app",
  "build": {
    "beforeBuildCommand": "cd ../src-frontend && npm run build",
    "beforeDevCommand": "",
    "frontendDist": "../src-frontend/dist",
    "devUrl": "http://127.0.0.1:5173"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* http://localhost:* ws://127.0.0.1:* ws://localhost:*; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' https:;",
      "capabilities": ["main-capability"]
    },
    "windows": [{
      "label": "main",
      "title": "StoryForge (草苔)",
      "width": 1400,
      "height": 900,
      "center": true,
      "fullscreen": false,
      "resizable": true,
      "visible": true,
      "transparent": false,
      "decorations": true,
      "useHttpsScheme": false
    }]
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
