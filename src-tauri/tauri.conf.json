{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StoryForge",
  "version": "0.1.0",
  "identifier": "com.storyforge.app",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "cd ../src-frontend && npm run dev",
    "frontendDist": "../src-frontend/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "security": {
      "csp": null,
      "capabilities": ["main-capability"]
    },
    "windows": [{
      "label": "main",
      "title": "StoryForge (草苔)",
      "width": 1400,
      "height": 900,
      "center": true,
      "fullscreen": false,
      "resizable": true
    }]
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
